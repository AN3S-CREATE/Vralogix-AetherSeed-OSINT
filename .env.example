# =============================================================================
# Veralogix AetherSeed OSINT — example environment.
# Copy to `.env` and adjust. NEVER commit a real .env. All values have safe
# local-first defaults; the platform runs with an empty .env.
# =============================================================================

# --- Core ---
AETHERSEED_ENV=dev                         # dev | prod
AETHERSEED_LOG_LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR
AETHERSEED_LOG_JSON=false                   # true => JSON logs (prod)
AETHERSEED_DATA_DIR=./data                  # sqlite, assets, audit logs live here

# --- Database ---
# Default: local SQLite. For prod use e.g.:
# AETHERSEED_DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/aetherseed
AETHERSEED_DATABASE_URL=sqlite+pysqlite:///./data/aetherseed.sqlite3

# --- Acquisition ---
AETHERSEED_ACQ_USER_AGENT=AetherSeedBot/0.1 (+https://veralogix.example/osint)
AETHERSEED_ACQ_RESPECT_ROBOTS=true          # override per-run with --ignore-robots
AETHERSEED_ACQ_MAX_CONCURRENCY=8
AETHERSEED_ACQ_POLITE_DELAY_MS=750
AETHERSEED_ACQ_REQUEST_TIMEOUT_S=30
AETHERSEED_ACQ_MAX_ASSET_BYTES=52428800     # 50 MiB per asset cap
# Comma-separated CIDR/host allowlist for SSRF egress. Empty => public internet
# only (private/loopback/link-local ranges are always blocked).
AETHERSEED_ACQ_EGRESS_ALLOWLIST=
AETHERSEED_ACQ_PROXY_URL=                   # e.g. http://user:pass@proxy:8080

# --- AI (AetherMind) ---
AETHERSEED_AI_BACKEND=ollama                # ollama | openai | anthropic | null
AETHERSEED_AI_OLLAMA_HOST=http://localhost:11434
AETHERSEED_AI_MODEL=llama3.1
AETHERSEED_AI_EMBED_MODEL=nomic-embed-text
AETHERSEED_AI_TEMPERATURE=0.2
AETHERSEED_AI_ENABLE_CLOUD_FALLBACK=false   # feature flag; requires key below
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Vector store ---
AETHERSEED_VECTOR_BACKEND=chroma            # chroma | none
AETHERSEED_VECTOR_DIR=./data/chroma

# --- Seeding safety budgets ---
AETHERSEED_SEED_MAX_NEW_PER_HOUR=100
AETHERSEED_SEED_REQUIRE_APPROVAL=true
AETHERSEED_SEED_BUDGET_USD=0                # 0 => local-only, no paid calls

# --- Queue / cache (optional) ---
AETHERSEED_REDIS_URL=redis://localhost:6379/0

# --- Graph (optional persistent backend) ---
AETHERSEED_GRAPH_BACKEND=networkx           # networkx | neo4j
AETHERSEED_NEO4J_URI=bolt://localhost:7687
AETHERSEED_NEO4J_USER=neo4j
AETHERSEED_NEO4J_PASSWORD=

# --- API / web ---
AETHERSEED_API_HOST=0.0.0.0
AETHERSEED_API_PORT=8000
AETHERSEED_CORS_ORIGINS=http://localhost:3000

# --- Compliance (POPIA) ---
AETHERSEED_PII_REDACTION=true               # redact PII in logs/exports by default
AETHERSEED_RETENTION_DAYS=365               # 0 => keep forever
